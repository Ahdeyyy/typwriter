{
  "name": "typwriter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@fontsource/iosevka": "^5.2.5",
    "mode-watcher": "^1.1.0"
  },
  "overrides": {
    "@codemirror/language": "6.12.4",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3"
  }
}
