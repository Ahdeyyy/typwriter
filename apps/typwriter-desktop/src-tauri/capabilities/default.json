{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "log:default",
    "store:default",
    "core:window:allow-set-title",
    "core:app:allow-set-app-theme",
    "dialog:default"
  ]
}
